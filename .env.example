# ──────────────────────────────────────────────
# AI-Powered Financial Document Similarity Finder
# Environment Variables — Copy to .env and customize
# ──────────────────────────────────────────────

# ─── PostgreSQL ───
POSTGRES_DB=fdsf_db
POSTGRES_USER=fdsf_user
POSTGRES_PASSWORD=fdsf_secret_2026

# ─── JWT Authentication ───
JWT_SECRET=super-secret-jwt-key-change-in-production-2026
JWT_EXPIRATION_MS=86400000    # 24 hours

# ─── Embedding Service ───
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ─── File Storage ───
FILE_STORAGE_PATH=/data/uploads
MAX_FILE_SIZE_MB=50

# ─── Qdrant ───
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=financial_documents

# ─── Search Defaults ───
SEARCH_TOP_K=5
SEARCH_THRESHOLD=0.70

# ─── Chunking ───
CHUNK_SIZE=800
CHUNK_OVERLAP=0
MAX_CHUNKS_PER_DOC=50

# ─── Logging ───
LOG_LEVEL=info
