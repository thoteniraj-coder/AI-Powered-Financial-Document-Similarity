export MVNW_DIR="$( cd "$( dirname "$0" )" && pwd )"
export MVNW_REPOURL="https://repo.maven.apache.org/maven2"
export MVNW_USERNAME=""
export MVNW_PASSWORD=""
export MVNW_VERSION="3.9.7"

if [ -z "$MAVEN_HOME" ]; then
  # Very basic fallback that assumes maven is somehow magically available or the wrapper jar is correct
  exec java -jar "$MVNW_DIR/.mvn/wrapper/maven-wrapper.jar" "$@"
else
  exec "$MAVEN_HOME/bin/mvn" "$@"
fi
